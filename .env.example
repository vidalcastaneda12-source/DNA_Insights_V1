# Copy to .env and edit. .env is gitignored.

# DuckDB analytical database
GENOME_DUCKDB_PATH=data/genome.duckdb

# Encrypted SQLite (SQLCipher) for personal state
APP_DB_PATH=data/app.db
# REQUIRED — choose a strong, locally stored passphrase. No default; the app will refuse to start without it.
APP_DB_PASSPHRASE=

# Raw uploads, snapshots, source dumps
ARCHIVE_PATH=archive

# Master switch for any network egress. Default off.
EXTERNAL_CALLS_ENABLED=false

# LLM model used for NL queries / audience rendering (Anthropic SDK)
LLM_MODEL=claude-opus-4-7

# Optional. Required only when external_calls_enabled=true and an LLM feature is invoked.
ANTHROPIC_API_KEY=

# Override the default reference panel root (~/.cache/genome/imputation/).
# IMPUTATION_PANEL_ROOT=

# Override the default annotations download cache root
# (~/.cache/genome/annotations/).
# ANNOTATIONS_DOWNLOAD_ROOT=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
